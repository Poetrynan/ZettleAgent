*.AppImage
*.deb
*.rpm

# ── AI / IDE helpers ──────────────────────────────────────────
.comate/
.mimocode/
.claude
.claude/

# ── Large RELEASE assets (build-time only, NOT for git) ───────
# OCR (~20 MB) lives in src-tauri/resources/ocr_models/ and IS committed.
# CI/local `download-model` still fetches embedding + WASM; OCR step skips when valid.
src-tauri/resources/embed_models/
src-tauri/resources/webview/
public/models/
public/ort-wasm-simd-threaded*.wasm
public/ort-wasm-simd-threaded*.mjs
public/fonts/
public/css/
public/pdf.min.mjs
public/pdf.worker.min.mjs
# Large ONNX only — do not blanket-ignore ocr_models/
src-tauri/resources/embed_models/**/*.onnx
public/models/**/*.onnx

# build:prod generates this locally (~1.4 MB); committed stub is katex-inlined.stub.ts
src/lib/katex-inlined.css.ts

# ── NSIS installer output ──
src-tauri/target/release/bundle/nsis/*.exe

# ── Documents (project-local, not for git) ──
documents/

# ── Internal docs (not for GitHub Pages / public) ──
docs/AGENT_ORCHESTRATION.md
docs/FIRST_RELEASE_GUIDE.md
docs/PACKAGING_RELEASE_QA.md
