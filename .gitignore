/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Rust / Tauri ──────────────────────────────────────────────
src-tauri/target/
src-tauri/target2/
src-tauri/gen/

# ── App Data (runtime files, not source) ─────────────────────
*.db
*.db-wal
*.db-shm

# ── Env / Secrets ───────────────────────────────────────────
.env
.env.*

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

